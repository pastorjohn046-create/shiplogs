{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "customer"] }
      },
      "required": ["uid", "email", "role"]
    },
    "Shipment": {
      "title": "Shipment",
      "description": "Logistics shipment details and tracking history.",
      "type": "object",
      "properties": {
        "trackingId": { "type": "string" },
        "type": { "type": "string", "enum": ["Flight", "Shipment"] },
        "status": { "type": "string", "enum": ["Pending", "In Transit", "Custom Clearance", "Delivered"] },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "status": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "location": { "type": "string" },
              "photoUrl": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "customerEmail": { "type": "string", "format": "email" },
        "userId": { "type": "string" },
        "origin": { "type": "string" },
        "destination": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["trackingId", "type", "status", "customerEmail", "origin", "destination"]
    },
    "Ticket": {
      "title": "Ticket",
      "description": "Customer support ticket.",
      "type": "object",
      "properties": {
        "shipmentId": { "type": "string" },
        "customerId": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "string" },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["customerId", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/shipments/{shipmentId}": {
      "schema": "Shipment",
      "description": "Shipment tracking data."
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Support tickets."
    }
  }
}
